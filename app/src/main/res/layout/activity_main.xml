<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFF5F5F5">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="普微助手"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FF1A73E8"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="智能话术生成工具"
        android:textSize="14sp"
        android:textColor="#FF666666"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <!-- 权限状态 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="12dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="权限状态"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FF333333"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="无障碍服务"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_accessibility_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="❌ 未启用"
                android:textSize="14sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_accessibility"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="开启无障碍服务"
            android:background="@drawable/bg_button_primary"
            android:textColor="#FFFFFFFF"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="悬浮窗权限"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_overlay_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="❌ 未授权"
                android:textSize="14sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_overlay"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="开启悬浮窗权限"
            android:background="@drawable/bg_button_primary"
            android:textColor="#FFFFFFFF"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- API 配置 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="API 配置"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FF333333"
                android:paddingBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DeepSeek API Key"
                android:textSize="14sp"
                android:textColor="#FF666666"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/et_api_key"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_edittext"
                android:padding="12dp"
                android:textSize="14sp"
                android:inputType="textPassword"
                android:hint="sk-..." />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="API 地址"
                android:textSize="14sp"
                android:textColor="#FF666666"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/et_api_url"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_edittext"
                android:padding="12dp"
                android:textSize="14sp"
                android:inputType="textUri"
                android:hint="https://api.deepseek.com/..." />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="模型"
                android:textSize="14sp"
                android:textColor="#FF666666"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <Spinner
                android:id="@+id/sp_model"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_edittext"
                android:padding="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="系统提示词"
                android:textSize="14sp"
                android:textColor="#FF666666"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/et_prompt"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/bg_edittext"
                android:padding="12dp"
                android:textSize="14sp"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:hint="输入系统提示词..." />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="自动生成话术"
                    android:textSize="14sp"
                    android:textColor="#FF333333" />
                <Switch
                    android:id="@+id/sw_auto_generate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- 按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="8dp">

        <Button
            android:id="@+id/btn_test"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="测试生成"
            android:background="@drawable/bg_button_secondary"
            android:textColor="#FF1A73E8"
            android:layout_marginRight="8dp" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="保存配置"
            android:background="@drawable/bg_button_primary"
            android:textColor="#FFFFFFFF" />

    </LinearLayout>

</LinearLayout>
